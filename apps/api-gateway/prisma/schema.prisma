generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ===== Device catalog & user devices =====
model DeviceCatalog {
  slug        String       @id
  label       String
  vendor      String
  modality    String
  transport   String
  services    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userDevices UserDevice[]
}

model UserDevice {
  id          String        @id @default(cuid())
  userId      String
  catalogSlug String
  nickname    String?
  transport   String
  pairedAt    DateTime      @default(now())
  lastSeenAt  DateTime      @default(now())
  identifiers Json?
  meta        Json?

  catalog     DeviceCatalog @relation(fields: [catalogSlug], references: [slug])

  @@index([userId])
  @@index([catalogSlug])
}

// ===== Core models =====
model Encounter {
  id          String   @id
  caseId      String
  patientId   String
  clinicianId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  status      String   // 'open' | 'closed'

  appointments Appointment[]
  erxOrders    ErxOrder[]
  labOrders    LabOrder[]
  payments     Payment[]
}

model Appointment {
  id          String   @id
  encounterId String
  sessionId   String
  caseId      String
  clinicianId String
  patientId   String
  startsAt    DateTime
  endsAt      DateTime
  status      String   // 'pending' | 'confirmed' | 'canceled' | 'completed'

  priceCents         Int
  currency           String   // 'ZAR'
  platformFeeCents   Int
  clinicianTakeCents Int
  paymentProvider    String   // 'paystack' | 'stripe' | 'flutterwave' | 'manual'
  paymentRef         String?
  meta               String?  // JSON-as-text

  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([clinicianId])
  @@index([startsAt])
  @@index([status])
}

model ErxOrder {
  id          String   @id
  kind        String
  encounterId String
  sessionId   String
  caseId      String
  patientId   String
  clinicianId String
  drug        String
  sig         String
  createdAt   DateTime @default(now())
  encounter   Encounter @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([clinicianId])
  @@index([createdAt])
}

model LabOrder {
  id          String   @id
  kind        String
  encounterId String
  sessionId   String
  caseId      String
  patientId   String
  clinicianId String
  panel       String
  createdAt   DateTime @default(now())
  encounter   Encounter @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([clinicianId])
  @@index([createdAt])
}

model Payment {
  id          String   @id
  encounterId String
  caseId      String
  amountCents Int
  currency    String
  status      String   // 'initiated' | 'captured' | 'refunded' | 'failed'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  meta        String?
  encounter   Encounter @relation(fields: [encounterId], references: [id])

  @@index([status])
  @@index([updatedAt])
}

model Televisit {
  id              String  @id
  title           String?
  startsAtMs      BigInt
  durationMin     Int
  joinOpenLeadSec Int
  joinCloseLagSec Int
}

model Ticket {
  id        String   @id
  visitId   String
  userId    String
  token     String
  issuedAt  BigInt
  expiresAt BigInt
}

model RuntimeEvent {
  id                String   @id
  ts                BigInt
  kind              String
  encounterId       String?
  patientId         String?
  clinicianId       String?
  payload           String?  // JSON-as-text
  targetPatientId   String?
  targetClinicianId String?
  targetAdmin       Boolean? @default(false)

  @@index([ts])
  @@index([kind])
  @@index([targetPatientId])
  @@index([targetClinicianId])
}

// ===== Medications & Reminders (new) =====

enum MedicationStatus {
  Active
  Completed
  OnHold
}

enum ReminderStatus {
  Pending
  Taken
  Missed
}

model Medication {
  id         String   @id @default(cuid())
  patientId  String?              // link to patient (optional in demo)
  patient    PatientProfile? @relation(fields: [patientId], references: [id])
  name       String
  dose       String?
  frequency  String?              // e.g. 'BID', 'OD'
  route      String?              // e.g. PO, IV
  started    DateTime?            // when therapy started
  lastFilled DateTime?            // last pharmacy fill
  status     MedicationStatus     // 'Active' | 'Completed' | 'OnHold'
  orderId    String?              // optional external order id (eRx)
  source     String?              // 'erx' | 'manual' | 'import'
  meta       Json?                // arbitrary metadata
  reminders  Reminder[]           // back-relation
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([createdAt])
}

model Reminder {
  id           String   @id @default(cuid())
  medicationId String?              // optional link to Medication
  medication   Medication? @relation(fields: [medicationId], references: [id])
  patientId    String?              // owner patient id (optional)
  patient      PatientProfile? @relation(fields: [patientId], references: [id])
  name         String               // e.g. 'Lisinopril'
  dose         String?
  time         String?              // scheduled time (HH:MM) or textual
  status       ReminderStatus       // 'Pending' | 'Taken' | 'Missed'
  snoozedUntil DateTime?            // when snooze expires (nullable)
  source       String?              // 'manual' | 'erx' | 'import'
  meta         Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([time])
  @@index([createdAt])
}

// ===== Profiles ===== 
model ClinicianProfile {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  displayName             String?
  specialty               String?
  gender                  String?
  phone                   String?
  email                   String?
  photoUrl                String?
  boardCertificateUrl     String?
  boardCertificateNumber  String?
  boardCertificateIssuer  String?
  boardCertificateExpires DateTime?
  idNumber                String?
  idIssuingCountry        String?
  idExpiry                DateTime?
  qualification           String?
  qualificationYear       Int?
  qualificationInstitution String?
  otherQualifications     String?
  addressLine1            String?
  addressLine2            String?
  city                    String?
  postalCode              String?
  country                 String?

  // Financial / payout
  feeCents                Int      @default(0)
  currency                String   @default("ZAR")
  payoutAccountId         String?

  // Professional Indemnity / Malpractice insurance
  piInsuranceProvider     String?
  piInsurancePolicyName   String?
  piInsuranceCoverType    String?
  piInsuranceExpiry       DateTime?
  piInsuranceNumber       String?

  // Training & lifecycle
  trainingScheduledAt     DateTime?
  trainingCompleted       Boolean  @default(false)
  status                  String   @default("pending") // 'pending'|'approved'|'rejected'|'active'|'suspended'|'archived'
  disabled                Boolean  @default(false)
  archived                Boolean  @default(false)

  meta                    Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([specialty])
  @@index([status])
  @@index([feeCents])
}

model PatientProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  name                 String?   // added for signup form
  contactEmail         String?   // email field
  phone                String?
  primaryComm          String?
  dob                  DateTime?
  idNumber             String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  postalCode           String?
  useAsDefaultDelivery Boolean  @default(false)
  heightCm             Int?
  weightKg             Int?
  photoUrl             String?
  allergies            String?  // JSON-as-text array
  medications          Medication[]
  reminders            Reminder[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ===== Devices & Vitals =====
model Device {
  id        String   @id @default(cuid())
  deviceId  String   @unique
  secret    String
  patientId String?
  roomId    String?
  vendor    String?
  category  String?
  model     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([vendor, category, model])
}

model VitalSample {
  id        String   @id @default(cuid())
  patientId String
  deviceId  String
  t         DateTime
  vType     String
  valueNum  Float
  unit      String?
  roomId    String?

  @@index([patientId, t])
  @@index([roomId, t])
  @@index([deviceId, t])
}

// ===== Delegations & Records ===== 
model ConsentGrant {
  id          String   @id @default(cuid())
  patientId   String
  delegateId  String
  scope       String
  startsAt    DateTime @default(now())
  endsAt      DateTime?
  revokedAt   DateTime?

  @@index([patientId])
  @@index([delegateId])
  @@index([scope])
  @@index([startsAt])
}

model EhrIndex {
  id            String   @id @default(cuid())
  recordId      String
  patientHash   String
  clinicianHash String
  contentHash   String
  uri           String
  kind          String
  chain         String   @default("offchain-dev")
  txId          String?
  createdAt     DateTime @default(now())

  @@index([recordId])
  @@index([chain])
  @@index([txId])
}

// ===== Partners ===== 
model PharmacyPartner {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([name])
}

model LabPartner {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([name])
}

// ===== Logistics ===== 
model Delivery {
  id          String   @id @default(cuid())
  orderId     String
  encounterId String
  patientId   String
  clinicianId String?
  riderId     String?
  partnerId   String?
  status      String
  priceCents  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([encounterId])
  @@index([orderId])
  @@index([patientId])
  @@index([clinicianId])
  @@index([riderId])
  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
}

model Draw {
  id          String   @id @default(cuid())
  orderId     String
  encounterId String
  patientId   String
  clinicianId String?
  phlebId     String?
  partnerId   String?
  status      String
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime @updatedAt

  @@index([encounterId])
  @@index([orderId])
  @@index([patientId])
  @@index([clinicianId])
  @@index([phlebId])
  @@index([partnerId])
  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
}

// ===== Location tracking ===== 
model LocationPing {
  id       String   @id @default(cuid())
  kind     String
  entityId String
  orderId  String?
  lat      Float
  lng      Float
  at       DateTime @default(now())

  @@index([kind, entityId, at])
  @@index([orderId])
  @@index([at])
}

// ===== Finance ===== 
model Payout {
  id          String   @id @default(cuid())
  role        String
  entityId    String
  periodStart DateTime
  periodEnd   DateTime
  amountCents Int
  currency    String   @default("ZAR")
  status      String   @default("pending")
  meta        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([role, entityId])
  @@index([status])
  @@index([periodStart, periodEnd])
}

model AuditEvent {
  id        String   @id @default(cuid())
  kind      String
  actorId   String?
  actorRole String?
  subjectId String?
  meta      Json?
  at        DateTime @default(now())

  @@index([kind, at])
  @@index([actorId])
  @@index([subjectId])
}

model EncounterAnchor {
  id          String   @id @default(cuid())
  encounterId String   @unique
  contentHash String
  chain       String
  txId        String?
  anchoredAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([chain])
  @@index([txId])
}

// ===== New: Schedule & Consult Policies ===== 
model ClinicianSchedule {
  id         String   @id @default(cuid())
  userId     String   @unique
  country    String   @default("ZA")
  timezone   String   @default("Africa/Johannesburg")
  template   String   // JSON string
  exceptions String   // JSON string
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model AdminConsultPolicy {
  id                    String   @id @default("singleton")
  minStandardMinutes    Int      @default(30)
  minFollowupMinutes    Int      @default(15)
  bufferAfterMinutes    Int      @default(5)
  joinGracePatientMin   Int      @default(5)
  joinGraceClinicianMin Int      @default(5)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ClinicianConsultSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  defaultStandardMin Int      @default(45)
  defaultFollowupMin Int      @default(20)
  minAdvanceMinutes  Int      @default(30)
  maxAdvanceDays     Int      @default(30)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

model ClinicianRefundPolicy {
  id                   String   @id @default(cuid())
  userId               String   @unique
  within24hPercent     Int      @default(50)
  noShowPercent        Int      @default(0)
  clinicianMissPercent Int      @default(100)
  networkProrate       Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}
