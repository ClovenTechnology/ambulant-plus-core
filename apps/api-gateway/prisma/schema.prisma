// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ===== Organizations =====
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
}

// ===== Organization settings / locale (put near Organization / settings area) =====
model OrganizationSettings {
  orgId               String   @id
  defaultCountry      String   @default("ZA") @db.VarChar(2)
  defaultLocale       String   @default("en-ZA") @db.VarChar(12)
  defaultCurrency     String   @default("ZAR") @db.VarChar(3)
  supportedLocales    String[] @default(["en-ZA", "fr-FR", "pt-PT", "af-ZA"])
  supportedCurrencies String[] @default(["ZAR", "USD", "EUR"])

  weekStartsOn String @default("monday")
  timezone     String @default("Africa/Johannesburg")

  updatedAt       DateTime @updatedAt
  updatedByUserId String?

  // optional relation later:
  // org Organization @relation(fields:[orgId], references:[id], onDelete: Cascade)
}

model UserLocalePreference {
  id       String  @id @default(cuid())
  userId   String  @unique
  country  String? @db.VarChar(2)
  locale   String? @db.VarChar(12)
  currency String? @db.VarChar(3)
  timezone String? @db.VarChar(64)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId String @default("org-default")

  @@index([orgId])
}

// Multi-currency clinician fees (supports auto-currency by country, but keeps explicit fees)
enum ClinicianFeeKind {
  STANDARD
  FOLLOWUP
  PROCEDURE
}

model ClinicianFee {
  id              String           @id @default(cuid())
  clinicianUserId String
  kind            ClinicianFeeKind
  currency        String           @db.VarChar(3)
  amountMinor     Int // store minor units (cents)
  active          Boolean          @default(true)

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?

  orgId     String   @default("org-default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinician ClinicianProfile @relation(fields: [clinicianUserId], references: [userId], onDelete: Cascade)

  @@index([clinicianUserId, kind, currency, active])
  @@index([orgId])
}

// ===== Device catalog & user devices =====
model DeviceCatalog {
  slug        String       @id
  label       String
  vendor      String
  modality    String
  transport   String
  services    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userDevices UserDevice[]
}

model UserDevice {
  id          String   @id @default(cuid())
  userId      String
  catalogSlug String
  nickname    String?
  transport   String
  pairedAt    DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  identifiers Json?
  meta        Json?

  catalog DeviceCatalog @relation(fields: [catalogSlug], references: [slug])

  @@index([userId])
  @@index([catalogSlug])
}

// ===== Core models =====
model Encounter {
  id          String   @id
  caseId      String
  patientId   String
  clinicianId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  status      String // 'open' | 'closed'

  // Tenant
  orgId String @default("org-default")

  appointments Appointment[]
  erxOrders    ErxOrder[]
  labOrders    LabOrder[]
  payments     Payment[]

  // NEW: clinical detail / analytics
  diagnoses         EncounterDiagnosis[]
  labResults        LabResult[]
  clinicalFindings  ClinicalFinding[]
  clinicalEvidence  ClinicalEvidence[]
  clinicalArtifacts ClinicalArtifact[]

  // NEW: surgery domain
  surgicalCases  SurgicalCase[]
  surgicalEvents SurgicalProcedureEvent[]

  @@index([orgId])
}

model Appointment {
  id          String   @id
  encounterId String
  sessionId   String
  caseId      String
  clinicianId String
  patientId   String
  startsAt    DateTime
  endsAt      DateTime
  status      String // 'pending' | 'confirmed' | 'canceled' | 'completed'

  priceCents         Int
  currency           String // 'ZAR'
  platformFeeCents   Int
  clinicianTakeCents Int
  paymentProvider    String // 'paystack' | 'stripe' | 'flutterwave' | 'manual'
  paymentRef         String?
  meta               String? // JSON-as-text

  // Tenant
  orgId String @default("org-default")

  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([clinicianId])
  @@index([startsAt])
  @@index([status])
  @@index([orgId])
  // Optional idempotency guard per tenant.
  @@index([orgId, clinicianId, patientId, startsAt, endsAt])
}

// ---- UPDATED: encounter-aware + flexible payload (keeps legacy fields)
model ErxOrder {
  id          String @id
  kind        String
  encounterId String
  sessionId   String
  caseId      String
  patientId   String
  clinicianId String

  // Legacy single-item support (now optional for flexibility)
  drug String?
  sig  String?

  // New multi-item / extras
  meds         Json? // e.g. [{drug,dose,route,freq,duration,qty,notes}]
  labTests     Json? // e.g. [{name,notes}]
  notes        String?
  status       String  @default("queued") // queued | sent | fulfilled | canceled
  dispenseCode String?

  createdAt DateTime @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([patientId])
  @@index([clinicianId])
  @@index([encounterId, status])
  @@index([createdAt])
}

model LabOrder {
  id          String   @id
  kind        String
  encounterId String
  sessionId   String
  caseId      String
  patientId   String
  clinicianId String
  panel       String
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  encounter Encounter @relation(fields: [encounterId], references: [id])

  // NEW: linked results
  results LabResult[]

  @@index([patientId])
  @@index([clinicianId])
  @@index([encounterId, status])
  @@index([createdAt])
}

model Payment {
  id          String   @id
  encounterId String
  caseId      String
  amountCents Int
  currency    String
  status      String // 'initiated' | 'captured' | 'refunded' | 'failed'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  meta        Json? // JSON payload (funding method, membershipId, etc.)

  // Tenant
  orgId String @default("org-default")

  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([status])
  @@index([updatedAt])
  @@index([orgId])
}

// ===== Televisits (SFU) + Join Tickets + Consent =====
enum TelevisitStatus {
  planned
  live
  ended
  cancelled
  archived
}

enum TelevisitRole {
  patient
  clinician
  staff
  observer
  admin
}

model Televisit {
  id     String          @id @default(cuid())
  roomId String          @unique
  status TelevisitStatus @default(planned)

  scheduledStartAt DateTime
  scheduledEndAt   DateTime
  joinOpensAt      DateTime
  joinClosesAt     DateTime

  // Optional: link to your Encounter/Appointment models later
  encounterId   String?
  appointmentId String?

  // Recommended: tenant guard (consistent with rest of schema)
  orgId String @default("org-default")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets  TelevisitJoinTicket[]
  consents TelevisitConsent[]

  @@index([status, scheduledStartAt])
  @@index([roomId, joinOpensAt, joinClosesAt])
  @@index([orgId])
}

model TelevisitJoinTicket {
  id      String    @id @default(cuid())
  visitId String
  visit   Televisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  uid  String
  role TelevisitRole

  // store ONLY hash (never store raw join token)
  tokenHash String @unique @db.VarChar(128)

  issuedAt   DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?

  ipHash    String? @db.VarChar(128)
  userAgent String?

  // Recommended: tenant guard
  orgId String @default("org-default")

  @@index([visitId, uid, role])
  @@index([expiresAt])
  @@index([orgId])
}

model TelevisitConsent {
  id      String    @id @default(cuid())
  visitId String
  visit   Televisit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  uid  String
  role TelevisitRole

  consentVersion String
  consentDocHash String @db.VarChar(128) // hash of the consent text you presented

  // scopes you can query later (recording, AI assistance, device streaming, etc)
  scopes Json

  acceptedAt DateTime @default(now())
  locale     String?
  ipHash     String?  @db.VarChar(128)
  userAgent  String?

  // Recommended: tenant guard
  orgId String @default("org-default")

  @@unique([visitId, uid, role, consentVersion])
  @@index([visitId, uid, role])
  @@index([orgId])
}

model RuntimeEvent {
  id                String   @id @default(cuid())
  ts                BigInt
  kind              String
  encounterId       String?
  patientId         String?
  clinicianId       String?
  severity          String? // 'low' | 'moderate' | 'high'
  payload           Json? // structured JSON (InsightCore, alerts, etc.)
  targetPatientId   String?
  targetClinicianId String?
  targetAdmin       Boolean? @default(false)

  // Tenant (optional for cross-tenant broadcasts)
  orgId String?

  @@index([ts])
  @@index([kind])
  @@index([patientId, ts])
  @@index([encounterId, ts])
  @@index([kind, severity, ts])
  @@index([targetPatientId])
  @@index([targetClinicianId])
  @@index([orgId])
}

// ===== Presence & Audit =====
enum PresenceActorType {
  PATIENT
  CLINICIAN
  PHLEB
  RIDER
  SHOPPER
  ADMIN
  CLINICIAN_STAFF_MEDICAL
  CLINICIAN_STAFF_NON_MEDICAL
}

enum AuditActorType {
  PATIENT
  CLINICIAN
  PHLEB
  RIDER
  SHOPPER
  ADMIN
  CLINICIAN_STAFF_MEDICAL
  CLINICIAN_STAFF_NON_MEDICAL
  SYSTEM // for background jobs, webhooks, etc
}

model AuthCredential {
  id           String @id @default(cuid())
  email        String @unique @db.VarChar(320)
  passwordHash String

  actorType PresenceActorType @default(PATIENT) // PATIENT | CLINICIAN | ADMIN | ...
  disabled  Boolean           @default(false)

  orgId String @default("org-default")

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([actorType])
  @@index([orgId])
  @@index([email, disabled])
}

model PasswordResetToken {
  id String @id @default(cuid())

  // store ONLY hash (never raw token)
  tokenHash String @unique @db.VarChar(128)

  email String @db.VarChar(320)

  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  requestedByIp String?
  requestedByUa String?

  orgId String @default("org-default")

  @@index([email, expiresAt])
  @@index([expiresAt])
  @@index([orgId, createdAt])
}

model PresenceSession {
  id         String            @id @default(cuid())
  userId     String
  actorType  PresenceActorType
  actorRefId String?
  app        String // 'patient-app' | 'clinician-app' | 'admin-dashboard' | etc
  startedAt  DateTime          @default(now())
  lastSeenAt DateTime
  endedAt    DateTime?
  ipCountry  String?
  ipCity     String?
  userAgent  String?
  meta       Json?

  @@index([actorType, lastSeenAt])
  @@index([userId, startedAt])
  @@index([actorType, app, lastSeenAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // who
  actorUserId String?
  actorType   AuditActorType
  actorRefId  String?

  // where
  app       String
  sessionId String?

  // what
  action      String
  entityType  String?
  entityId    String?
  description String?

  // context
  ip        String?
  ipCountry String?
  ipCity    String?
  userAgent String?
  meta      Json?

  @@index([createdAt])
  @@index([actorType, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}

/**
 * =========================================================
 * Org RBAC (Admin / Backoffice)
 * - Departments → Designations → default Roles
 * - Users get direct Roles too
 * - Roles have Scopes (string keys)
 * - Role Requests (pending/approved/denied) for workflow
 * =========================================================
 */

enum OrgRoleRequestStatus {
  pending
  approved
  denied
}

model OrgDepartment {
  id        String   @id @default(cuid())
  orgId     String   @default("org-default")
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  designations OrgDesignation[]

  // ✅ added back-relations
  users        OrgUser[]
  roleRequests OrgRoleRequest[]

  @@unique([orgId, name])
  @@index([orgId, active])
  @@index([orgId, name])
}

model OrgDesignation {
  id           String   @id @default(cuid())
  orgId        String   @default("org-default")
  departmentId String
  name         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department OrgDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  // Default roles for this designation
  roles OrgDesignationRole[]

  // Users assigned to this designation
  users OrgUser[]

  // ✅ added back-relation
  roleRequests OrgRoleRequest[]

  @@unique([orgId, departmentId, name])
  @@index([orgId, departmentId, active])
  @@index([departmentId])
}

model OrgRole {
  id          String   @id @default(cuid())
  orgId       String   @default("org-default")
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Scopes attached to this role (string keys, e.g. "settings.roles")
  scopes OrgRoleScope[]

  // Links
  designationLinks OrgDesignationRole[]
  userLinks        OrgUserRole[]
  requestLinks     OrgRoleRequestRole[]

  @@unique([orgId, name])
  @@index([orgId, active])
  @@index([orgId, name])
}

model OrgRoleScope {
  id        String   @id @default(cuid())
  roleId    String
  scope     String
  createdAt DateTime @default(now())

  role OrgRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, scope])
  @@index([scope])
  @@index([roleId])
}

model OrgUser {
  id    String @id @default(cuid())
  orgId String @default("org-default")

  // External / upstream identity reference:
  // - can be Auth0 "sub"
  // - or your internal gateway user id
  externalUserId String @unique

  email  String? @db.VarChar(320)
  name   String?
  active Boolean @default(true)

  departmentId  String?
  designationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department  OrgDepartment?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation OrgDesignation? @relation(fields: [designationId], references: [id], onDelete: SetNull)

  // Direct roles on the user (in addition to designation default roles)
  roles OrgUserRole[]

  // Role requests submitted by/for this user
  roleRequests OrgRoleRequest[]

  @@index([orgId, active])
  @@index([orgId, email])
  @@index([departmentId])
  @@index([designationId])
}

model OrgUserRole {
  id        String @id @default(cuid())
  orgUserId String
  roleId    String

  grantedBy String?
  grantedAt DateTime  @default(now())
  revokedAt DateTime?

  user OrgUser @relation(fields: [orgUserId], references: [id], onDelete: Cascade)
  role OrgRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([orgUserId, roleId])
  @@index([roleId])
  @@index([orgUserId])
}

model OrgDesignationRole {
  id            String   @id @default(cuid())
  designationId String
  roleId        String
  createdAt     DateTime @default(now())

  designation OrgDesignation @relation(fields: [designationId], references: [id], onDelete: Cascade)
  role        OrgRole        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([designationId, roleId])
  @@index([roleId])
  @@index([designationId])
}

model OrgRoleRequest {
  id     String               @id @default(cuid())
  orgId  String               @default("org-default")
  status OrgRoleRequestStatus @default(pending)

  // Useful even if user not provisioned yet
  requesterEmail String  @db.VarChar(320)
  requesterName  String?

  // Optional link to OrgUser (if known)
  orgUserId String?

  // Optional snapshot of org placement requested/associated
  departmentId  String?
  designationId String?

  // Admin decision
  reason    String?
  decidedBy String?
  decidedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        OrgUser?        @relation(fields: [orgUserId], references: [id], onDelete: SetNull)
  department  OrgDepartment?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation OrgDesignation? @relation(fields: [designationId], references: [id], onDelete: SetNull)

  // Requested roles (many)
  roles OrgRoleRequestRole[]

  @@index([orgId, status, createdAt])
  @@index([requesterEmail])
  @@index([orgUserId])
}

model OrgRoleRequestRole {
  id        String @id @default(cuid())
  requestId String
  roleId    String

  request OrgRoleRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  role    OrgRole        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([requestId, roleId])
  @@index([roleId])
  @@index([requestId])
}

// ===== Medications & Reminders =====
enum MedicationStatus {
  Active
  Completed
  OnHold
}

enum ReminderStatus {
  Pending
  Taken
  Missed
}

model Medication {
  id           String           @id @default(cuid())
  patientId    String?
  patient      PatientProfile?  @relation(fields: [patientId], references: [id])
  name         String
  dose         String?
  frequency    String?
  route        String?
  started      DateTime?
  lastFilled   DateTime?
  status       MedicationStatus
  orderId      String?
  source       String?
  durationDays Int?
  meta         Json?
  reminders    Reminder[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([createdAt])
}

model Reminder {
  id           String          @id @default(cuid())
  medicationId String?
  medication   Medication?     @relation(fields: [medicationId], references: [id])
  patientId    String?
  patient      PatientProfile? @relation(fields: [patientId], references: [id])
  name         String
  dose         String?
  time         String?
  status       ReminderStatus
  snoozedUntil DateTime?
  source       String?
  meta         Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([time])
  @@index([createdAt])
}

model ReminderPushSubscription {
  id        String         @id @default(cuid())
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id])

  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([patientId])
}

// ===== Conditions / Vaccinations / Operations =====
model Condition {
  id        String          @id @default(cuid())
  patientId String?
  patient   PatientProfile? @relation(fields: [patientId], references: [id])

  name        String
  status      String
  diagnosedAt DateTime?
  facility    String?
  clinician   String?
  onAmbulant  Boolean?  @default(false)
  notes       String?

  fileKey  String?
  fileName String?
  ehrTxId  String?

  source     String?
  recordedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([createdAt])
}

model Vaccination {
  id        String          @id @default(cuid())
  patientId String?
  patient   PatientProfile? @relation(fields: [patientId], references: [id])

  vaccine   String
  date      DateTime?
  batch     String?
  facility  String?
  clinician String?
  notes     String?

  fileKey  String?
  fileName String?
  ehrTxId  String?

  source     String?
  recordedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([vaccine])
  @@index([date])
  @@index([createdAt])
}

model Operation {
  id        String          @id @default(cuid())
  patientId String?
  patient   PatientProfile? @relation(fields: [patientId], references: [id])

  title          String
  date           DateTime?
  facility       String?
  surgeon        String?
  coClinicians   String[]
  clinicianCount Int?      @default(1)
  notes          String?

  fileKey  String?
  fileName String?
  ehrTxId  String?

  source     String?
  recordedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([date])
  @@index([createdAt])
}

model Allergy {
  id        String          @id @default(cuid())
  patientId String?
  patient   PatientProfile? @relation(fields: [patientId], references: [id])

  substance   String
  reaction    String?
  severity    String?
  status      String?
  criticality String?
  recordedAt  DateTime @default(now())

  @@index([patientId])
  @@index([status])
  @@index([recordedAt])
}

// ===== Profiles =====
model ClinicianProfile {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  displayName              String?
  specialty                String?
  gender                   String?
  phone                    String?
  email                    String?
  photoUrl                 String?
  boardCertificateUrl      String?
  boardCertificateNumber   String?
  boardCertificateIssuer   String?
  boardCertificateExpires  DateTime?
  idNumber                 String?
  idIssuingCountry         String?
  idExpiry                 DateTime?
  qualification            String?
  qualificationYear        Int?
  qualificationInstitution String?
  otherQualifications      String?
  addressLine1             String?
  addressLine2             String?
  city                     String?
  postalCode               String?
  country                  String?

  practiceName          String?
  practiceNumber        String?
  regulatorBody         String?
  regulatorRegistration String?

  acceptsMedicalAid Boolean  @default(false)
  acceptedSchemes   String[] @default([])

  feeCents        Int     @default(0)
  currency        String  @default("ZAR")
  payoutAccountId String?

  // NEW: multi-currency / multi-kind fees
  feesV2 ClinicianFee[]

  piInsuranceProvider   String?
  piInsurancePolicyName String?
  piInsuranceCoverType  String?
  piInsuranceExpiry     DateTime?
  piInsuranceNumber     String?

  trainingScheduledAt DateTime?
  trainingCompleted   Boolean   @default(false)
  status              String    @default("pending")
  disabled            Boolean   @default(false)
  archived            Boolean   @default(false)

  online            Boolean   @default(false)
  onlineSeq         BigInt?
  lastSeenAt        DateTime?
  lastBookedAt      DateTime?
  recentBookedCount Int       @default(0)
  meta              Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([specialty])
  @@index([status])
  @@index([feeCents])
}

// ===== NEW: Medical Aid Policies (near PatientProfile) =====
model MedicalAidPolicy {
  id        String         @id @default(cuid())
  patientId String
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  schemeName       String
  planName         String?
  membershipNumber String
  dependentCode    String?
  principalName    String?

  coversTelemedicine    Boolean @default(true)
  telemedicineCoverType String  @default("full") // "full" | "partial"
  coPaymentType         String? // "fixed" | "percent"
  coPaymentValue        Int?

  notes String?

  comFileOriginalName String?
  comFileStoredAs     String?
  hasCom              Boolean @default(false)

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([schemeName])
  @@index([membershipNumber])
  @@index([patientId, isDefault])
}

model PatientProfile {
  id           String  @id @default(cuid())
  userId       String? @unique
  name         String?
  contactEmail String?
  phone        String?
  primaryComm  String?

  gender String? // 'Male' | 'Female' | 'Other' | 'Unknown'

  dob                  DateTime?
  idNumber             String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  postalCode           String?
  useAsDefaultDelivery Boolean   @default(false)
