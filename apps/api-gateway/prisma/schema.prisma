// ===== Wallet / Vouchers =====
enum WalletScope {
  SHOP
  PLAN
  APPOINTMENT
}

enum WalletHoldStatus {
  HELD
  CAPTURED
  RELEASED
  EXPIRED
}

enum WalletEntryKind {
  CREDIT
  DEBIT
  ADJUSTMENT
}

enum VoucherKind {
  CREDIT // pure wallet credit
  PLAN_INTENT // credits wallet, may auto-upgrade plan (constraints.planTarget)
  FREE_CONSULT // clinician-sponsored acquisition voucher (appointment only)
}

enum VoucherSponsorType {
  PLATFORM
  CLINICIAN
}

model WalletAccount {
  id       String @id @default(cuid())
  userId   String @unique
  currency String @default("ZAR")

  // posted balance (credits - debits)
  balanceZar Int @default(0)
  // reserved holds (reduces availability)
  heldZar    Int @default(0)

  orgId     String   @default("org-default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries WalletEntry[]
  holds   WalletHold[]

  @@index([orgId])
}

model WalletEntry {
  id        String          @id @default(cuid())
  accountId String
  kind      WalletEntryKind
  scope     WalletScope?
  amountZar Int // CREDIT: +, DEBIT: -, ADJUSTMENT: +/- (but keep logic sane)
  currency  String          @default("ZAR")

  sponsorType VoucherSponsorType?
  sponsorId   String? // clinician userId (if sponsorType=CLINICIAN) else null/platform

  // linkage
  voucherId String?
  holdId    String?
  refType   String?
  refId     String?
  txRef     String? // e.g. plan checkout tx, shop tx, appointmentId

  meta      Json?
  orgId     String   @default("org-default")
  createdAt DateTime @default(now())

  account WalletAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([txRef])
  @@index([voucherId])
  @@index([orgId])
}

model WalletHold {
  id        String           @id @default(cuid())
  accountId String
  scope     WalletScope
  amountZar Int
  currency  String           @default("ZAR")
  status    WalletHoldStatus @default(HELD)

  txRef   String? @unique // tie holds to checkout tx safely (optional)
  refType String?
  refId   String?

  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  orgId String @default("org-default")

  account WalletAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, status])
  @@index([orgId])
}

model VoucherCode {
  id String @id @default(cuid())

  // store hash, not raw code (safer if DB leaks)
  codeHash  String @unique
  codeLast4 String

  kind     VoucherKind
  valueZar Int
  currency String      @default("ZAR")

  sponsorType VoucherSponsorType
  sponsorId   String? // clinician userId if sponsorType=CLINICIAN

  // constraints examples:
  // { scopes:["SHOP","PLAN"], expiresAtISO, singleUse:true, planTarget:"premium", autoApply:true, platformFeeHoldZar:90 }
  constraints Json?

  maxUses   Int     @default(1)
  usedCount Int     @default(0)
  active    Boolean @default(true)

  validFrom DateTime?
  expiresAt DateTime?

  // if clinician-sponsored: we reserve platform fee hold upfront
  sponsorHoldId String?

  orgId           String   @default("org-default")
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  redemptions VoucherRedemption[]

  @@index([active, expiresAt])
  @@index([kind])
  @@index([sponsorType, sponsorId])
  @@index([orgId])
}

model VoucherRedemption {
  id          String @id @default(cuid())
  voucherId   String
  userId      String
  creditedZar Int

  // linkage
  walletEntryId String?
  meta          Json?

  orgId      String   @default("org-default")
  redeemedAt DateTime @default(now())

  voucher VoucherCode @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@index([voucherId, redeemedAt])
  @@index([userId, redeemedAt])
  @@index([orgId])
}

model PromoToken {
  id          String    @id @default(cuid())
  code        String    @unique
  kind        String    @default("consult")
  description String?
  amountCents Int       @default(0)
  currency    String    @default("ZAR")
  maxUses     Int       @default(1)
  usedCount   Int       @default(0)
  patientId   String?
  active      Boolean   @default(true)
  validFrom   DateTime?
  expiresAt   DateTime?
  meta        Json?

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([active, expiresAt])
}

model AuditEvent {
  id        String   @id @default(cuid())
  kind      String
  actorId   String?
  actorRole String?
  subjectId String?
  meta      Json?
  at        DateTime @default(now())

  @@index([kind, at])
  @@index([actorId])
  @@index([subjectId])
}

model EncounterAnchor {
  id          String    @id @default(cuid())
  encounterId String    @unique
  contentHash String
  chain       String
  txId        String?
  anchoredAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([chain])
  @@index([txId])
}

// ===== Schedule & Consult Policies =====
model ClinicianSchedule {
  id         String   @id @default(cuid())
  userId     String   @unique
  country    String   @default("ZA")
  timezone   String   @default("Africa/Johannesburg")
  template   String
  exceptions String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model AdminConsultPolicy {
  id                    String   @id @default("singleton")
  minStandardMinutes    Int      @default(30)
  minFollowupMinutes    Int      @default(15)
  bufferAfterMinutes    Int      @default(5)
  joinGracePatientMin   Int      @default(5)
  joinGraceClinicianMin Int      @default(5)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model ClinicianConsultSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  defaultStandardMin Int      @default(45)
  defaultFollowupMin Int      @default(20)
  minAdvanceMinutes  Int      @default(30)
  maxAdvanceDays     Int      @default(30)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
}

model ClinicianRefundPolicy {
  id                   String   @id @default(cuid())
  userId               String   @unique
  within24hPercent     Int      @default(50)
  noShowPercent        Int      @default(0)
  clinicianMissPercent Int      @default(100)
  networkProrate       Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}

// ===== MedReach / CarePort enhancements =====
enum MedReachStatus {
  Assigned
  EnRoute
  Arrived
  Completed
  Canceled
}

enum CarePortStatus {
  Assigned
  AtPharmacy
  OutForDelivery
  Delivered
  Canceled
}

model MedReachJob {
  id             String         @id @default(cuid())
  externalId     String
  labId          String
  phlebId        String
  patientName    String
  patientAddress String
  windowLabel    String?
  status         MedReachStatus
  eta            String?
  etaAt          DateTime?
  orgId          String         @default("org-default")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  lab      LabPartner?             @relation(fields: [labId], references: [id])
  timeline MedReachTimelineEntry[]

  @@unique([orgId, externalId])
  @@index([labId])
  @@index([phlebId])
  @@index([status])
  @@index([createdAt])
  @@index([orgId])
  @@index([labId, status, createdAt])
  @@index([etaAt])
}

model MedReachTimelineEntry {
  id     String   @id @default(cuid())
  jobId  String
  status String
  note   String?
  at     DateTime @default(now())

  job MedReachJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, at])
}

model CarePortJob {
  id             String         @id @default(cuid())
  externalId     String
  pharmacyId     String
  riderId        String
  patientName    String
  patientAddress String
  status         CarePortStatus
  eta            String?
  etaAt          DateTime?
  orgId          String         @default("org-default")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  pharmacy PharmacyPartner?        @relation(fields: [pharmacyId], references: [id])
  timeline CarePortTimelineEntry[]

  @@unique([orgId, externalId])
  @@index([pharmacyId])
  @@index([riderId])
  @@index([status])
  @@index([createdAt])
  @@index([orgId])
  @@index([pharmacyId, status, createdAt])
  @@index([etaAt])
}

model CarePortTimelineEntry {
  id     String   @id @default(cuid())
  jobId  String
  msg    String
  entity String?
  lat    Float?
  lng    Float?
  at     DateTime @default(now())

  job CarePortJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, at])
}

// ===== Clinical Workspaces (Findings / Evidence / Annotations / Artifacts) =====
model ClinicalFinding {
  id String @id @default(cuid())

  patientId   String
  encounterId String
  clinicianId String?

  specialty String // 'std' | 'dental' | 'derm' | etc
  status    String   @default("draft") // draft | final | archived
  title     String
  note      String?
  severity  String?
  tags      String[] @default([])

  // Location is workspace-defined (e.g. {kind:'std', context:'screening'} )
  location Json

  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId     String    @default("org-default")
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  evidence    ClinicalEvidence[]
  annotations ClinicalAnnotation[]

  @@index([orgId])
  @@index([encounterId, updatedAt])
  @@index([patientId, updatedAt])
  @@index([specialty, updatedAt])
}

model ClinicalEvidence {
  id String @id @default(cuid())

  patientId   String
  encounterId String
  clinicianId String?

  specialty String
  status    String @default("ready") // ready | processing | failed

  findingId String?
  finding   ClinicalFinding? @relation(fields: [findingId], references: [id], onDelete: SetNull)

  // Media + capture source + location are flexible JSON
  location Json
  source   Json
  media    Json

  capturedAt DateTime?
  meta       Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  orgId     String    @default("org-default")
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  annotations ClinicalAnnotation[]

  @@index([orgId])
  @@index([encounterId, updatedAt])
  @@index([patientId, updatedAt])
  @@index([findingId, updatedAt])
  @@index([specialty, updatedAt])
}

model ClinicalAnnotation {
  id String @id @default(cuid())

  patientId   String
  encounterId String
  clinicianId String?

  specialty String

  evidenceId String
  evidence   ClinicalEvidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  findingId String?
  finding   ClinicalFinding? @relation(fields: [findingId], references: [id], onDelete: SetNull)

  type     String // pin | bbox | note | etc
  payload  Json
  location Json

  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId String @default("org-default")

  @@index([orgId])
  @@index([encounterId, createdAt])
  @@index([patientId, createdAt])
  @@index([evidenceId, createdAt])
  @@index([specialty, createdAt])
}

model ClinicalArtifact {
  id String @id @default(cuid())

  patientId   String
  encounterId String
  clinicianId String?

  specialty String // 'std'
  kind      String // 'std_workspace_state' | 'std_results_bundle' | etc
  status    String @default("active") // active | archived

  payload Json

  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId     String    @default("org-default")
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@unique([orgId, encounterId, specialty, kind])
  @@index([orgId])
  @@index([encounterId, updatedAt])
  @@index([patientId, updatedAt])
  @@index([specialty, kind, updatedAt])
}

// ===== Surgical Workspaces =====
enum SurgicalCaseStatus {
  planned
  in_progress
  completed
  cancelled
}

enum SurgicalPriority {
  routine
  urgent
  emergency
}

model SurgicalCase {
  id              String             @id @default(cuid())
  encounterId     String
  patientId       String
  clinicianId     String?
  specialtyDomain String // general | orthopaedics | urology | neurosurgery | cardiothoracic | ent | obgyn
  priority        SurgicalPriority   @default(routine)
  status          SurgicalCaseStatus @default(planned)

  preOpDiagnosis  String?
  indication      String?
  risksNotes      String?
  allergyNotes    String?
  medicationNotes String?

  checklist     Json? // same shape as client SafetyChecklist
  procedureNote Json? // same shape as client ProcedureNote
  postOpPlan    Json? // same shape as client PostOpPlan

  orgId     String   @default("org-default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  encounter Encounter                @relation(fields: [encounterId], references: [id])
  events    SurgicalProcedureEvent[]

  @@index([encounterId])
  @@index([patientId])
  @@index([clinicianId])
  @@index([specialtyDomain, priority, status])
  @@index([orgId, createdAt])
}

model SurgicalProcedureEvent {
  id             String  @id @default(cuid())
  surgicalCaseId String
  encounterId    String
  patientId      String
  clinicianId    String?

  eventType  String // created | timeout | incision | specimen_sent | closure | post_op_note | complication | etc.
  occurredAt DateTime @default(now())
  note       String?
  payload    Json?

  orgId     String   @default("org-default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  surgicalCase SurgicalCase @relation(fields: [surgicalCaseId], references: [id], onDelete: Cascade)
  encounter    Encounter    @relation(fields: [encounterId], references: [id])

  @@index([surgicalCaseId, occurredAt])
  @@index([encounterId, occurredAt])
  @@index([patientId, occurredAt])
  @@index([eventType, occurredAt])
  @@index([orgId, occurredAt])
}

// ===== Shop / Inventory / Orders =====
enum ShopChannel {
  CLINICIAN
  PATIENT
  MEDREACH
  CAREPORT
}

enum ShopOrderStatus {
  PENDING
  PAID
  CANCELLED
  FAILED
  REFUNDED
}

model ShopProduct {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String?
  type          String   @default("merch")
  tags          String[] @default([])
  images        String[] @default([])
  fallbackImage String?
  active        Boolean  @default(true)

  unitAmountZar Int?
  saleAmountZar Int?

  allowBackorder Boolean @default(false)
  maxQtyPerOrder Int     @default(99)

  orgId String @default("org-default")

  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ShopVariant[]
  channels ShopProductChannel[]

  @@index([orgId])
  @@index([active, updatedAt])
  @@index([type])
}

model ShopVariant {
  id        String  @id @default(cuid())
  productId String
  sku       String  @unique
  label     String
  active    Boolean @default(true)

  unitAmountZar     Int
  saleUnitAmountZar Int?

  imageUrl       String?
  inStock        Boolean  @default(true)
  stockQty       Int?
  allowBackorder Boolean?

  orgId String @default("org-default")

  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   ShopProduct             @relation(fields: [productId], references: [id], onDelete: Cascade)
  channels  ShopVariantChannel[]
  movements ShopInventoryMovement[]

  @@index([productId])
  @@index([orgId])
  @@index([active])
  @@index([inStock])
}

model ShopProductChannel {
  id        String      @id @default(cuid())
  productId String
  channel   ShopChannel

  orgId String @default("org-default")

  product ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, channel])
  @@index([channel])
  @@index([orgId])
}

model ShopVariantChannel {
  id        String      @id @default(cuid())
  variantId String
  channel   ShopChannel

  orgId String @default("org-default")

  variant ShopVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, channel])
  @@index([channel])
  @@index([orgId])
}

model ShopInventoryMovement {
  id        String   @id @default(cuid())
  variantId String
  delta     Int
  reason    String?
  note      String?
  createdAt DateTime @default(now())

  orgId String @default("org-default")

  variant ShopVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, createdAt])
  @@index([orgId, createdAt])
}

model ShopOrder {
  id       String          @id @default(cuid())
  status   ShopOrderStatus @default(PENDING)
  channel  ShopChannel
  currency String          @default("ZAR")

  subtotalZar Int @default(0)
  shippingZar Int @default(0)
  discountZar Int @default(0)
  totalZar    Int @default(0)

  promoCode       String?
  customerEmail   String?
  shippingAddress Json?

  provider     String  @default("paystack")
  sessionId    String? @unique
  receiptUrl   String?
  providerMeta Json?

  orgId String @default("org-default")

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  items ShopOrderItem[]

  @@index([status, createdAt])
  @@index([channel, createdAt])
  @@index([orgId, createdAt])
}

model ShopOrderItem {
  id            String  @id @default(cuid())
  orderId       String
  productId     String
  variantId     String?
  sku           String?
  name          String
  unitAmountZar Int
  quantity      Int

  orgId String @default("org-default")

  order ShopOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@index([sku])
  @@index([orgId])
}

// ===== Org / RBAC (Admin RBAC, corrected wiring) =====
model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  designations Designation[]

  // ✅ back-relations
  adminUsers   AdminUserProfile[]
  roleRequests RoleRequest[]
}

model Designation {
  id           String   @id @default(cuid())
  departmentId String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department        @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  roles      DesignationRole[]

  // ✅ back-relations
  adminUsers   AdminUserProfile[]
  roleRequests RoleRequest[]

  @@unique([departmentId, name])
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scopes           RoleScope[]
  designationLinks DesignationRole[]

  // ✅ back-relations
  userRoles        UserRole[]
  roleRequestRoles RoleRequestRole[]
}

model RoleScope {
  roleId String
  scope  String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, scope])
  @@index([scope])
}

model DesignationRole {
  designationId String
  roleId        String
  designation   Designation @relation(fields: [designationId], references: [id], onDelete: Cascade)
  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([designationId, roleId])
  @@index([roleId])
}

model AdminUserProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  email         String   @unique
  name          String?
  departmentId  String?
  designationId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  department  Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)

  // ✅ relation to UserRole join model
  roles UserRole[]

  @@index([departmentId])
  @@index([designationId])
}

model UserRole {
  id String @id @default(cuid())

  adminUserId String
  roleId      String

  adminUser AdminUserProfile @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  role      Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([adminUserId, roleId])
  @@index([roleId])
  @@index([adminUserId])
}

enum RoleRequestStatus {
  pending
  approved
  denied
}

model RoleRequest {
  id            String            @id @default(cuid())
  userId        String?
  email         String
  name          String?
  departmentId  String?
  designationId String?
  status        RoleRequestStatus @default(pending)
  reason        String?
  decidedBy     String?
  decidedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  department  Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)

  roles RoleRequestRole[]
}

model RoleRequestRole {
  roleRequestId String
  roleId        String

  roleRequest RoleRequest @relation(fields: [roleRequestId], references: [id], onDelete: Cascade)
  role        Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleRequestId, roleId])
  @@index([roleId])
}

// ===== NEW: Encounter-level diagnoses / lab results & population analytics =====
model EncounterDiagnosis {
  id          String   @id @default(cuid())
  encounterId String
  patientId   String
  clinicianId String?
  icd10       String
  description String?
  kind        String
  status      String
  syndrome    String?
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  encounter Encounter @relation(fields: [encounterId], references: [id])

  @@index([encounterId])
  @@index([patientId])
  @@index([clinicianId])
  @@index([icd10])
  @@index([kind])
  @@index([status])
  @@index([syndrome])
  @@index([createdAt])
  @@index([syndrome, createdAt])
}

model LabResult {
  id          String   @id @default(cuid())
  orderId     String
  encounterId String
  patientId   String
  clinicianId String?
  loincCode   String?
  name        String
  isPositive  Boolean?
  valueNum    Float?
  unit        String?
  flag        String?
  createdAt   DateTime @default(now())

  order     LabOrder  @relation(fields: [orderId], references: [id])
  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId])
  @@index([patientId])
  @@index([loincCode])
  @@index([createdAt])
}

model Icd10SyndromeMap {
  id       String  @id @default(cuid())
  codeFrom String
  codeTo   String
  syndrome String
  comment  String?

  @@index([codeFrom, codeTo])
  @@index([syndrome])
}

model PopulationStat {
  id         String  @id @default(cuid())
  country    String
  region     String?
  district   String?
  postalCode String?
  year       Int
  population Int

  @@index([country, region, district, postalCode, year])
}

// ===== NEW: Clinician onboarding / dispatch / training =====
model ClinicianOnboarding {
  id          String @id @default(cuid())
  clinicianId String @unique
  status      String @default("pending")

  paymentPlan   String?
  depositPaid   Boolean   @default(false)
  nextPaymentAt DateTime?

  trainingSlotId String?
  trainingNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainingSlot ClinicianTrainingSlot? @relation(fields: [trainingSlotId], references: [id])
  dispatches   ClinicianDispatch[]

  @@index([status])
}

model ClinicianTrainingSlot {
  id          String   @id @default(cuid())
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int      @default(1)
  usedCount   Int      @default(0)
  mode        String   @default("virtual")
  meetingUrl  String?
  trainerName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  onboardings ClinicianOnboarding[]

  @@index([startsAt])
  @@index([mode])
}

model ClinicianDispatch {
  id           String    @id @default(cuid())
  onboardingId String
  clinicianId  String
  courier      String
  trackingCode String
  trackingUrl  String?
  etaDate      DateTime?
  status       String    @default("prepared")
  shippedAt    DateTime?
  deliveredAt  DateTime?
  notes        String?

  // NEW (nullable): notification tracking
  notifiedAt       DateTime?
  notifiedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  onboarding ClinicianOnboarding     @relation(fields: [onboardingId], references: [id])
  items      ClinicianDispatchItem[]

  @@index([clinicianId])
  @@index([courier, trackingCode])
  @@index([status])
  @@index([notifiedAt])
  @@index([notifiedByUserId])
}

model ClinicianDispatchItem {
  id          String  @id @default(cuid())
  dispatchId  String
  kind        String
  label       String
  quantity    Int     @default(1)
  deviceId    String?
  isMandatory Boolean @default(true)
  isShipped   Boolean @default(true)

  // NEW (nullable): inventory traceability
  sku          String? @db.VarChar(64)
  serialNumber String? @db.VarChar(128)

  dispatch ClinicianDispatch @relation(fields: [dispatchId], references: [id])

  @@index([dispatchId])
  @@index([kind])
  @@index([sku])
  @@index([serialNumber])
}

// ===== NEW: Precomputed InsightCore heatmaps =====
model InsightCoreHeatmap {
  id String @id @default(cuid())

  weekStart DateTime

  country    String
  region     String?
  district   String?
  postalCode String?

  syndrome String
  ageBand  String?
  gender   String?

  encounterCount      Int @default(0)
  finalDiagnosisCount Int @default(0)
  ruledOutCount       Int @default(0)
  distinctPatients    Int @default(0)

  positiveLabCount Int @default(0)
  alertCount       Int @default(0)

  population       Int?
  incidencePer100k Float?
  alertRatePer100k Float?

  riskScore Float?

  trendVsPrevWeek Float?
  zScore          Float?

  meta      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weekStart, country, region, district, syndrome])
  @@index([country, region, district, weekStart])
  @@index([syndrome, weekStart])
  @@index([riskScore])
  @@index([alertCount])
}
