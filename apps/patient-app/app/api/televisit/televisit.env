cat > televisit.env <<'EOF'
# HS256 secret for Tele-visit tokens (use any long random string in non-prod)
TELEVISIT_JWT_SECRET="replace-with-a-long-random-secret"
# Gate window (minutes): Start allowed X mins before, Y mins after end
JOIN_WINDOW_START_MIN="-10"
JOIN_WINDOW_END_MIN="15"
# Token TTL (seconds)
JOIN_TOKEN_TTL_SEC="90"
EOF
