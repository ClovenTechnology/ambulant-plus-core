# Televisit (dev defaults) — copy keys you need into your real .env.local / Vercel envs

# Join ticket TTL (seconds)
JOIN_TOKEN_TTL_SEC=90

# Gate window (minutes): allow join X mins before start, Y mins after end
JOIN_WINDOW_START_MIN=-10
JOIN_WINDOW_END_MIN=15

# Allow mock visit seeding when a visit isn't in the runtime store (DEV ONLY)
TELEVISIT_ALLOW_MOCK_VISITS=1

# LiveKit server credentials (required for /api/rtc/token)
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret

# Token TTL for insecure dev mode only
LIVEKIT_TOKEN_TTL_SEC=3600

# Allow minting RTC tokens without join-ticket verification (DEV ONLY; keep 0)
RTC_ALLOW_INSECURE_DEV_TOKENS=0

# Allow /api/rtc state store without x-uid (DEV ONLY; keep 0)
RTC_STORE_ALLOW_ANON=0
