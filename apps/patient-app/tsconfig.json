{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "es2020"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@ambulant/ui-shell": ["../../packages/ui-shell/src/index.tsx"],
      "@lib/*": ["src/lib/*"],
      "@runtime/*": ["../../packages/shared-runtime/src/*"],
      "@/*": ["./*"],
      "@components/*": ["components/*", "app/components/*"]
    },
    "types": ["node"],
    "strict": false,
    "noEmit": true,
    "isolatedModules": true,
    "plugins": [{ "name": "next" }],
    "strictNullChecks": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
