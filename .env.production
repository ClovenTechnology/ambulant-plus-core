# Database (compose network hostname `postgres` is used)
DATABASE_URL=postgresql://ambulant:supersecretpg@postgres:5432/ambulant?schema=public
SHADOW_DATABASE_URL=postgresql://ambulant:supersecretpg@postgres:5432/ambulant_shadow?schema=public

# pgbouncer
PGBOUNCER_LISTEN_ADDR=0.0.0.0
PGBOUNCER_LISTEN_PORT=6432
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=20

# LiveKit (keep as-is)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# MQTT (unchanged)
MQTT_URL=wss://z84856af.ala.eu-central-1.emqxsl.com:8084/mqtt
MQTT_USERNAME=iomt
MQTT_PASSWORD=supersecret
MQTT_TOPIC_ROOT=iomt
TEST_DEVICE_ID=HealthMonitor-001

# App ports
APIGW_PORT=3010
PATIENT_APP_PORT=3000
CLINICIAN_APP_PORT=3001
